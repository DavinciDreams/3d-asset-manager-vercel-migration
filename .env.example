# Environment Variables Template for 3D Asset Manager
# Copy this file to .env and replace placeholders with real values.

# Postgres connection string.
# If omitted in development, the app uses local SQLite: asset_manager_dev.sqlite3
DATABASE_URL=postgresql://user:password@host:5432/3d_asset_manager

# Docker Compose / Coolify Postgres password. The compose file builds
# DATABASE_URL from this value when running app + postgres together.
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Docker Compose / Coolify MinIO object storage. Model binaries, thumbnails,
# previews, generated assets, and future optimized/compressed derivatives should
# live here; Postgres keeps the metadata and object keys.
MINIO_ROOT_USER=asset-manager
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
S3_BUCKET=asset-manager
S3_REGION=us-east-1

# Shared secret used by the Tellus Cloudflare Durable Object when it writes
# /api/tellus/worlds/:worldId/state.
TELLUS_PERSISTENCE_API_TOKEN=replace-with-a-long-random-token

# Separate admin bearer token for in-world generation pipelines such as
# Instant Mesh. Send as: Authorization: Bearer <TELLUS_ADMIN_API_TOKEN>
# Admin uploads are tagged as Tellus generated assets. Set a default owner
# or send X-Asset-Username / X-Asset-User-Id per request.
TELLUS_ADMIN_API_TOKEN=replace-with-a-separate-long-random-admin-token
TELLUS_ADMIN_USER_ID=
TELLUS_ADMIN_USERNAME=tellusadmin

# Bearer token for API uploads and workflow automation. Send as:
# Authorization: Bearer <ASSET_MANAGER_API_TOKEN>
ASSET_MANAGER_API_TOKEN=replace-with-a-long-random-api-token

# Optional owner mapping for token uploads. If omitted, token uploads are
# service-owned (user_id null) but still manageable with the bearer token.
API_UPLOAD_USER_ID=
API_UPLOAD_USERNAME=

# Optional AI metadata enrichment. Without an API key, autotagging falls back to
# deterministic filename/metadata tags for local development and tests.
#
# OpenAI direct setup:
AI_AUTOTAG_PROVIDER=openai
AI_AUTOTAG_API_KEY=
AI_AUTOTAG_BASE_URL=https://api.openai.com/v1
AI_AUTOTAG_MODEL=gpt-4.1-mini
AI_AUTOTAG_TRANSPORT=openai
AI_AUTOTAG_TIMEOUT=120
AI_AUTOTAG_WORKER=1
AI_AUTOTAG_KICK_ON_REQUEST=1
AI_AUTOTAG_STALE_MINUTES=15
AI_AUTOTAG_ON_UPLOAD=1
AI_AUTOTAG_OVERWRITE_ON_UPLOAD=1
AI_AUTOTAG_INCLUDE_TITLE=1
AI_AUTOTAG_INCLUDE_DESCRIPTION=1
AI_AUTOTAG_USE_VISION=1
AI_AUTOTAG_RETRY_TEXT_ONLY=1
AI_AUTOTAG_USER_AGENT=3d-asset-manager/1.0

# Hyades Vision services use A2A JSON-RPC for the holo vision model:
# AI_AUTOTAG_PROVIDER=hyades
# AI_AUTOTAG_API_KEY=
# AI_AUTOTAG_BASE_URL=https://hyades.gnostr.cloud/a2a
# AI_AUTOTAG_MODEL=holo
# AI_AUTOTAG_TRANSPORT=a2a
#
# Hyades-specific names are also accepted:
# HYADES_API_KEY=
# HYADES_VISION_BASE_URL=https://hyades.gnostr.cloud/a2a
# HYADES_VISION_MODEL=holo
# HYADES_TRANSPORT=a2a
#
# Hyades OpenAI-compatible /v1 is still available for chat-compatible models:
# AI_AUTOTAG_BASE_URL=https://hyades.gnostr.cloud/v1
# AI_AUTOTAG_TRANSPORT=openai
#
# Z.AI Coding Plan remains supported for text-only enrichment:
# AI_AUTOTAG_PROVIDER=zai
# AI_AUTOTAG_BASE_URL=https://api.z.ai/api/coding/paas/v4
# AI_AUTOTAG_MODEL=glm-5.1
# AI_AUTOTAG_USE_VISION=0
#
# Z.AI Coding Plan with the local Vision MCP pre-pass:
# AI_AUTOTAG_PROVIDER=zai
# AI_AUTOTAG_API_KEY=
# AI_AUTOTAG_BASE_URL=https://api.z.ai/api/coding/paas/v4
# AI_AUTOTAG_MODEL=glm-5.1
# AI_AUTOTAG_TRANSPORT=zai-mcp
# AI_AUTOTAG_USE_VISION=1
# AI_AUTOTAG_ZAI_MCP=1
# AI_AUTOTAG_ZAI_MCP_REQUIRED=0
# AI_AUTOTAG_MCP_COMMAND=npx -y @z_ai/mcp-server@latest
# AI_AUTOTAG_MCP_TOOL=image_analysis
# AI_AUTOTAG_MCP_TIMEOUT=120
# Z_AI_MODE=ZAI
# Z_AI_API_KEY=
#
# Backward-compatible OpenAI-style names are still accepted:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_AUTOTAG_MODEL=gpt-4.1-mini

# Old MongoDB connection string, used only during migration.
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority

# Flask Secret Key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Flask Environment
FLASK_ENV=production

# Debug mode (set to false in production)
FLASK_DEBUG=false

# Optional upload limit in MB
MAX_UPLOAD_MB=100

# Optional conversion controls
ENABLE_CONVERSION=1
FBX2GLTF_BIN=/usr/local/bin/FBX2glTF
ASSIMP_BIN=assimp
NODE_BIN=node
FBX2VRMA_DIR=/app/tools

# Optional public port for docker compose.
PORT=8000
