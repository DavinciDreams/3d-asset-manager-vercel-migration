# Environment Variables Template for 3D Asset Manager
# Copy this file to .env and replace placeholders with real values.

# Postgres connection string.
# If omitted in development, the app uses local SQLite: asset_manager_dev.sqlite3
DATABASE_URL=postgresql://user:password@host:5432/3d_asset_manager

# Docker Compose / Coolify Postgres password. The compose file builds
# DATABASE_URL from this value when running app + postgres together.
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Docker Compose / Coolify MinIO object storage. Model binaries, thumbnails,
# previews, generated assets, and future optimized/compressed derivatives should
# live here; Postgres keeps the metadata and object keys.
MINIO_ROOT_USER=asset-manager
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
S3_BUCKET=asset-manager
S3_REGION=us-east-1

# Shared secret used by the Tellus Cloudflare Durable Object when it writes
# /api/tellus/worlds/:worldId/state.
TELLUS_PERSISTENCE_API_TOKEN=replace-with-a-long-random-token

# Old MongoDB connection string, used only during migration.
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority

# Flask Secret Key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Flask Environment
FLASK_ENV=production

# Debug mode (set to false in production)
FLASK_DEBUG=false

# Optional upload limit in MB
MAX_UPLOAD_MB=100

# Optional conversion controls
ENABLE_CONVERSION=1
FBX2GLTF_BIN=/usr/local/bin/FBX2glTF
ASSIMP_BIN=assimp
NODE_BIN=node
FBX2VRMA_DIR=/app/tools

# Optional public port for docker compose.
PORT=8000
